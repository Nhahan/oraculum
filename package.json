{
  "name": "oraculum",
  "version": "0.1.0-beta.3",
  "description": "Oracle-guided patch consultation for Claude Code and Codex.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "oraculum": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nhahan/oraculum.git"
  },
  "homepage": "https://github.com/Nhahan/oraculum",
  "bugs": {
    "url": "https://github.com/Nhahan/oraculum/issues"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "check": "npm run lint && npm run typecheck && npm run test",
    "dev": "tsx src/cli.ts",
    "format": "biome check --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai-native",
    "claude-code",
    "codex",
    "developer-tools",
    "harness-engineering",
    "oraculum"
  ],
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^18.19.130",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
